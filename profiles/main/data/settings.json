{
  "cSpell.language": "en-GB,nl,lorem",
  "cSpell.userWords": [
    "dialog",
    "findock",
    "Findock",
    "geist",
    "lumbermill",
    "montem",
    "neue",
    "Neue",
    "postgres",
    "Relevanssi",
    "separat",
    "storylane",
    "Storylane",
    "TRPC",
    "uidotdev",
    "usehooks",
    "webp",
    "zellij",
    "zimrc",
  ],
  "editor.accessibilitySupport": "off",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": false,
  "editor.fontSize": 16,
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.renderWhitespace": "none",
  "editor.stickyScroll.enabled": false,
  "files.trimTrailingWhitespace": true,
  "git.autofetch": true,
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "prettier.proseWrap": "always",
  "scm.defaultViewMode": "tree",
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
  ],
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "window.customTitleBarVisibility": "auto",
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.startupEditor": "none",
  "terminal.integrated.env.osx": {
    "CW_NEW_SESSION": "1",
  },
  "terminal.integrated.tabs.enabled": false,
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },
  "security.workspace.trust.untrustedFiles": "open",
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "[hosts]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "explorer.fileNesting.patterns": {
    "*.ts": "${dirname} ${capture}.js",
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "workbench.colorTheme": "Catppuccin Macchiato",
  "terminal.explorerKind": "external",
  "terminal.external.osxExec": "Alacritty.app",
  "githubPullRequests.pullBranch": "never",
  "workbench.activityBar.location": "top",
  "[liquid]": {
    "editor.defaultFormatter": "sissel.shopify-liquid",
    "editor.formatOnSave": true,
  },
  "emmet.includeLanguages": {
    "twig": "html",
  },
  "files.associations": {
    "config": "ssh-config",
    "*.html": "twig",
    "*.css": "tailwindcss",
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "[twig]": {
    "editor.defaultFormatter": "mblode.twig-language-2",
  },
  "git.ignoreRebaseWarning": true,
  "workbench.editor.labelFormat": "short",
  "[go]": {
    "editor.defaultFormatter": "golang.go",
  },
  "files.insertFinalNewline": true,
  "git.confirmSync": false,
  "workbench.editorAssociations": {
    "*.svg": "default",
  },
  "javascript.updateImportsOnFileMove.enabled": "never",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 6,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "html",
    "typescriptreact",
  ],

  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "telemetry.feedback.enabled": false,

  "chat.agent.enabled": false,
  "git.blame.editorDecoration.enabled": true,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "stylelint.configFile": "stylelint.config.ts",
  "stylelint.packageManager": "pnpm",
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome",
  },
  "editor.inlayHints.enabled": "off",
  "editor.minimap.enabled": false,
  "json.schemaDownload.trustedDomains": {
    "https://biomejs.dev": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://ui.shadcn.com/schema.json": true,
    "https://www.schemastore.org/": true,
  },
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.linux": {
    "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${env:PATH}",
  },
  "chat.disableAIFeatures": true,
  "syncSettings.crons": {
      "review": "0 * * * *",      // every hour
      "download": "30 9 * * *",    // at 9:30, every day
      "upload": "0 17 * * *"      // at 17:00, every day
  },
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.hideOnboarding": true,
}
